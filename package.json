{
  "name": "pyvista-org-dashboard",
  "version": "1.0.0",
  "private": true,
  "description": "Static GitHub-Pages dashboard for the PyVista org.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "fetch": "node scripts/fetch-data.js",
    "generate": "node scripts/generate-pages.js",
    "lint": "biome check .",
    "format": "biome format --write .",
    "test": "node --test tests/*.test.js"
  },
  "dependencies": {
    "@octokit/plugin-retry": "^7.1.4",
    "@octokit/plugin-throttling": "^9.4.0",
    "octokit": "^5.0.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.0"
  }
}
